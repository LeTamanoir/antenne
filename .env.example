# Telegram
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# Devices (comma-separated device:label pairs)
NVME_DEVICES=/dev/nvme0:NVMe
HDD_DEVICES=/dev/sda:HDD sda,/dev/sdb:HDD sdb

# Disk mounts (path:label pairs, comma-separated)
DISK_MOUNTS=/mnt/movies:Movies Drive,/mnt/tv:TV Drive,/:System Disk

# Thresholds
NVME_WARN_TEMP=70
NVME_CRIT_TEMP=80
HDD_WARN_TEMP=45
HDD_CRIT_TEMP=50
DISK_WARN_PERCENT=80
DISK_CRIT_PERCENT=90
RAM_WARN_PERCENT=85

# Daemon schedule
REPORT_HOUR=8
ALERT_INTERVAL_MINUTES=15
